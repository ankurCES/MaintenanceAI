server:
  port: 8080
  host: "0.0.0.0"

queue:
  type: "redis" # Options: "kafka", "redis"
  redis_url: "redis://127.0.0.1/"
  redis_stream: "maintenance_logs"
  # kafka_brokers: "localhost:9092"
  # kafka_topic: "maintenance_logs"

llm:
  provider: "ollama"
  model: "gpt-oss:120b"
  temperature: 0.1

heuristics:
  context_window_size: 50 
  trigger_levels:
    - "ERROR"
    - "FATAL"
    - "CRITICAL"

keys:
  # Enter your API keys below (Do not commit the actual config.yaml to version control)
  ollama: "YOUR_OLLAMA_API_KEY_HERE"
  gemini: "YOUR_GEMINI_API_KEY_HERE"
  mem0: "YOUR_MEM0_API_KEY_HERE"
